#!/usr/bin/env bash
#
# skillenv — pyenv for agent skills.
# Declare skills per-repo in .skillsrc; direnv activates them on cd.
#
#   skillenv init       scaffold .skillsrc + .envrc in the current repo
#   skillenv allow      trust the current .skillsrc (required after every change)
#   skillenv activate   sync skills and print env exports (called from .envrc)
#   skillenv status     show trust state and what is active
#   skillenv scan       inventory every skill installed on this machine
#   skillenv list       global skills, grouped by agent
#   skillenv install    install a skill (or browse+pick from a repo) into every detected agent's GLOBAL dir
#   skillenv uninstall  move a skill out of the global dirs (backed up, never deleted)
#   skillenv prompt     compact status for shell prompts (starship/p10k)
#   skillenv update     pull the latest skillenv (git checkout or re-download)
#
set -euo pipefail

SKILLENV_HOME="${SKILLENV_HOME:-$HOME/.skillenv}"
MANIFEST=".skillsrc"
MARKER=".managed-by-skillenv"

if command -v shasum >/dev/null 2>&1; then SHA="shasum -a 256"; else SHA="sha256sum"; fi

if [ -t 1 ] || [ "${SKILLENV_COLOR:-}" = "1" ]; then
  BOLD=$'\033[1m' DIM=$'\033[2m' CYAN=$'\033[36m' GREEN=$'\033[32m' RST=$'\033[0m'
else
  BOLD="" DIM="" CYAN="" GREEN="" RST=""
fi

note() { echo "skillenv: $*" >&2; }
die()  { note "$*"; exit 1; }

hash_str()  { printf %s "$1" | $SHA | awk '{print substr($1,1,12)}'; }
hash_file() { $SHA < "$1" | awk '{print $1}'; }

# ---------- manifest ----------

AGENTS="claude codex"
ISOLATION="merge"
SKILLS=""
DISABLES=""

parse_manifest() {
  set -f
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    # shellcheck disable=SC2086
    set -- $line
    [ "$#" -eq 0 ] && continue
    directive=$1; shift
    case "$directive" in
      agents)    AGENTS="$*" ;;
      isolation) ISOLATION="$1" ;;
      skill)     SKILLS="$SKILLS $1" ;;
      disable)   DISABLES="$DISABLES $1" ;;
      *) die "unknown directive '$directive' in $MANIFEST" ;;
    esac
  done < "$MANIFEST"
  set +f
  case "$ISOLATION" in merge|strict) ;; *) die "isolation must be 'merge' or 'strict'" ;; esac
  [ "$AGENTS" = "auto" ] && AGENTS=$(detect_agents)
  true
}

detect_agents() { # which supported agents are actually installed on this machine
  local found=""
  { [ -d "$HOME/.claude" ] || command -v claude >/dev/null 2>&1; }          && found="$found claude"
  { [ -d "$HOME/.codex" ] || command -v codex >/dev/null 2>&1; }            && found="$found codex"
  { [ -d "$HOME/.config/opencode" ] || command -v opencode >/dev/null 2>&1; } && found="$found opencode"
  echo "${found# }"
}

skill_name()  {
  local s=${1#github:}; s=${s#git:}; s=${s%/}
  s=${s##*/}  # last path component; @ref only ever lives here
  s=${s%@*}; s=${s%.git}
  printf '%s' "$s"
}
skill_desc() { # $1 SKILL.md path, $2 max display length (default 72) -> cleaned, ellipsis-truncated description
  local file=$1 max=${2:-72} raw
  raw=$(grep -m1 '^description:' "$file" 2>/dev/null) || return 0
  raw=${raw#description:}
  raw=${raw# }
  raw=${raw#\"}; raw=${raw%\"}
  case "$raw" in
    ""|">"|">-"|">+"|"|"|"|-"|"|+") return 0 ;; # YAML block-scalar marker — actual text is on later lines, not worth chasing
  esac
  if [ "${#raw}" -gt "$max" ]; then
    printf '%s…' "${raw:0:$((max - 1))}"
  else
    printf '%s' "$raw"
  fi
}
is_disabled() { local d; for d in $DISABLES; do [ "$d" = "$1" ] && return 0; done; return 1; }
in_manifest() { local s; for s in $SKILLS; do [ "$(skill_name "$s")" = "$1" ] && return 0; done; return 1; }

# ---------- trust gate (same model as `direnv allow`) ----------

trust_file() { echo "$SKILLENV_HOME/trust/$(hash_str "$PWD/$MANIFEST")"; }
is_trusted() { [ -f "$(trust_file)" ] && [ "$(cat "$(trust_file)")" = "$(hash_file "$MANIFEST")" ]; }

cmd_allow() {
  [ -f "$MANIFEST" ] || die "no $MANIFEST in $PWD"
  parse_manifest # fail fast on syntax errors before trusting
  local s abs=""
  for s in $SKILLS; do case "$s" in /*) abs="$abs $s" ;; esac; done
  if [ -n "$abs" ] && git ls-files --error-unmatch "$MANIFEST" >/dev/null 2>&1; then
    note "warning: $MANIFEST is tracked by git but points at machine-local absolute paths:"
    note "   $abs"
    note "  these resolve only on this machine — use github: sources in shared manifests"
  fi
  mkdir -p "$SKILLENV_HOME/trust"
  hash_file "$MANIFEST" > "$(trust_file)"
  note "trusted $PWD/$MANIFEST — re-enter the directory or run 'direnv reload'"
}

# ---------- skill sources ----------

REFRESH="" # a truthy value makes fetch_github/fetch_git update an already-cloned cache before using it

refresh_cache() { # $1 cache dir, $2 ref (may be empty), $3 display label — best-effort
  local cache=$1 ref=$2 label=$3 branch
  branch=$(git -C "$cache" rev-parse --abbrev-ref HEAD 2>/dev/null) || return 0
  [ "$branch" = HEAD ] && branch=$ref # detached = cloned at a tag; refetch the tag itself
  [ -n "$branch" ] || return 0
  note "refreshing $label"
  git -C "$cache" fetch --quiet --depth 1 origin "$branch" >&2 \
    && git -C "$cache" reset --quiet --hard FETCH_HEAD >&2 \
    || note "warning: cannot refresh $label — using the cached copy"
}

fetch_github() { # owner/repo[/sub/dir][@ref] -> echoes skill dir
  local spec=$1 ref="" sub="" owner repo rest cache
  case "$spec" in *@*) ref=${spec##*@}; spec=${spec%@*} ;; esac
  owner=${spec%%/*}; rest=${spec#*/}; repo=${rest%%/*}
  case "$rest" in */*) sub=${rest#*/} ;; esac
  cache="$SKILLENV_HOME/cache/github/$owner/${repo}${ref:+@$ref}"
  if [ ! -d "$cache/.git" ]; then
    note "fetching github.com/$owner/$repo${ref:+ ($ref)}"
    git clone --quiet --depth 1 ${ref:+--branch "$ref"} \
      "https://github.com/$owner/$repo.git" "$cache" >&2
  elif [ -n "$REFRESH" ]; then
    refresh_cache "$cache" "$ref" "github.com/$owner/$repo${ref:+ ($ref)}"
  fi
  echo "$cache${sub:+/$sub}"
}

fetch_git() { # any git url, with .git marking the repo boundary: url[/sub/dir][@ref]
  local spec=$1 url rest="" sub="" ref="" last cache
  case "$spec" in
    *.git/*) url="${spec%%.git/*}.git"; rest=${spec#*.git/} ;;
    *)       url=$spec ;;
  esac
  if [ -n "$rest" ]; then
    case "$rest" in *@*) ref=${rest##*@}; sub=${rest%@*} ;; *) sub=$rest ;; esac
  else
    last=${url##*/} # a ref can only follow the last path component (git@host: has its own @)
    case "$last" in *@*) ref=${last##*@}; url=${url%@"$ref"} ;; esac
  fi
  cache="$SKILLENV_HOME/cache/git/$(hash_str "$url")${ref:+@$ref}"
  if [ ! -d "$cache/.git" ]; then
    note "fetching $url${ref:+ ($ref)}"
    git clone --quiet --depth 1 ${ref:+--branch "$ref"} "$url" "$cache" >&2
  elif [ -n "$REFRESH" ]; then
    refresh_cache "$cache" "$ref" "$url${ref:+ ($ref)}"
  fi
  echo "$cache${sub:+/$sub}"
}

resolve_source() {
  case "$1" in
    github:*)    fetch_github "${1#github:}" ;;
    git:*)       fetch_git "${1#git:}" ;;
    ./*|../*|/*) echo "$1" ;;
    *) die "unsupported skill source: $1 (use github:owner/repo[/dir][@ref], git:<url>[/dir][@ref], or a local path)" ;;
  esac
}

# ---------- materialize into the repo ----------

agent_dir() {
  case "$1" in
    claude)   echo ".claude/skills" ;;
    codex)    echo ".codex/skills" ;;
    opencode) echo ".opencode/skills" ;;
    agents)   echo ".agents/skills" ;;
    *) die "unknown agent '$1' (known: claude codex opencode agents)" ;;
  esac
}

sync_project() {
  local agent dir d name s src dest resolved=""
  # resolve every source once (not per agent): an unreachable source (private
  # repo, someone else's absolute path) warns once and skips, without breaking
  # activation for everything else
  for s in $SKILLS; do
    if ! src=$(resolve_source "$s"); then
      note "warning: cannot fetch $s — skipped"; continue
    fi
    if [ ! -f "$src/SKILL.md" ]; then
      case "$s" in
        /*) note "warning: $s not found on this machine — absolute paths only resolve where they were written; shared manifests should use github: sources. skipped" ;;
        *)  note "warning: no SKILL.md at $s — skipped" ;;
      esac
      continue
    fi
    resolved="$resolved$s|$src
"
  done
  for agent in $AGENTS; do
    dir=$(agent_dir "$agent")
    mkdir -p "$dir"
    for d in "$dir"/*/; do # drop managed skills gone from the manifest
      [ -f "$d$MARKER" ] || continue
      name=${d%/}; name=${name##*/}
      in_manifest "$name" || { rm -rf "$d"; note "removed $dir/$name"; }
    done
    while IFS='|' read -r s src; do
      [ -n "$s" ] || continue
      name=$(skill_name "$s")
      dest="$dir/$name"
      if [ -e "$dest" ] && [ ! -f "$dest/$MARKER" ]; then
        note "skip $dest — exists but not managed by skillenv"
        continue
      fi
      # already materialized and identical -> skip the copy (keeps repeat cds fast)
      if [ -f "$dest/$MARKER" ] && diff -rq -x "$MARKER" -x .git "$src" "$dest" >/dev/null 2>&1; then
        continue
      fi
      rm -rf "$dest"
      cp -R "$src" "$dest"
      rm -rf "$dest/.git"
      printf '%s\n' "$s" > "$dest/$MARKER" # marker records the source; its mtime is the install date
    done <<< "$resolved"
  done
}

# ---------- shadow config dirs (global-skill isolation) ----------
#
# A shadow of ~/.claude or ~/.codex: every entry symlinked back to the real
# one (auth, settings, sessions stay shared) EXCEPT skills/, which we control:
#   strict -> empty; merge -> symlinks to each global skill minus `disable`d ones.
# Exported per-process via CLAUDE_CONFIG_DIR / CODEX_HOME, so other terminals
# and other repos are untouched, and leaving the directory restores everything.

need_shadow() { [ "$ISOLATION" = strict ] || [ -n "${DISABLES// /}" ]; }

build_shadow() { # $1 agent, $2 real config dir -> echoes shadow dir
  local agent=$1 real=$2 shadow entry base sk name
  shadow="$SKILLENV_HOME/shadow/$(hash_str "$PWD")/$agent"
  mkdir -p "$shadow"
  for entry in "$real"/* "$real"/.[!.]*; do
    [ -e "$entry" ] || continue
    base=${entry##*/}
    [ "$base" = "skills" ] && continue
    [ -L "$shadow/$base" ] && continue # linked on a previous run; target path never changes
    [ -e "$shadow/$base" ] && continue # agent wrote real state here; keep it
    ln -sfn "$entry" "$shadow/$base"
  done
  if [ "$agent" = claude ] && [ ! -L "$shadow/.claude.json" ] && [ -f "$HOME/.claude.json" ]; then
    # lives outside ~/.claude, but claude looks for it inside CLAUDE_CONFIG_DIR
    ln -sfn "$HOME/.claude.json" "$shadow/.claude.json"
  fi
  rm -rf "$shadow/skills"
  mkdir -p "$shadow/skills"
  if [ "$ISOLATION" = merge ]; then
    for sk in "$real"/skills/*/; do
      [ -d "$sk" ] || continue
      name=${sk%/}; name=${name##*/}
      is_disabled "$name" || ln -s "${sk%/}" "$shadow/skills/$name"
    done
  fi
  echo "$shadow"
}

# ---------- commands ----------

cmd_activate() {
  local agent shadow
  if [ ! -f "$MANIFEST" ]; then note "no $MANIFEST in $PWD — nothing to do"; return 0; fi
  if ! is_trusted; then
    note "$MANIFEST is new or has changed and is NOT trusted."
    note "review it, then run: skillenv allow"
    return 0
  fi
  parse_manifest
  sync_project
  if need_shadow; then
    for agent in $AGENTS; do
      case "$agent" in
        claude) shadow=$(build_shadow claude "$HOME/.claude"); echo "export CLAUDE_CONFIG_DIR='$shadow'" ;;
        codex)  shadow=$(build_shadow codex "$HOME/.codex");   echo "export CODEX_HOME='$shadow'" ;;
      esac
    done
  fi
}

cmd_prompt() { # compact status for shell prompts; prints nothing without a manifest
  [ -f "$MANIFEST" ] || return 0
  if ! is_trusted; then printf '!untrusted'; return 0; fi
  parse_manifest
  local out=$ISOLATION
  set -f
  # shellcheck disable=SC2086
  set -- $SKILLS;   [ "$#" -gt 0 ] && out="$out +$#"
  # shellcheck disable=SC2086
  set -- $DISABLES; [ "$#" -gt 0 ] && out="$out -$#"
  set +f
  printf '%s' "$out"
}

cmd_status() {
  [ -f "$MANIFEST" ] || die "no $MANIFEST in $PWD"
  if is_trusted; then echo "trust:     allowed"; else echo "trust:     NOT allowed (run: skillenv allow)"; fi
  parse_manifest
  echo "isolation: $ISOLATION"
  echo "agents:    $AGENTS"
  echo "skills:   ${SKILLS:- (none)}"
  echo "disabled: ${DISABLES:- (none)}"
  echo "shadow:    $SKILLENV_HOME/shadow/$(hash_str "$PWD")"
  echo "env:       CLAUDE_CONFIG_DIR=${CLAUDE_CONFIG_DIR:-<unset>} CODEX_HOME=${CODEX_HOME:-<unset>}"
}

refresh_global_skills() { # re-fetch every skillenv-managed global skill from its recorded source and reinstall it
  local agent sk s src seen=" "
  REFRESH=1
  for agent in $(detect_agents); do
    for sk in "$(agent_global_dir "$agent")"/*/; do
      [ -f "${sk}$MARKER" ] || continue
      s=$(head -1 "${sk}$MARKER" 2>/dev/null) || continue
      [ -n "$s" ] || continue
      case "$seen" in *" $s "*) continue ;; esac
      seen="$seen$s "
      if src=$(resolve_source "$s") && [ -f "$src/SKILL.md" ]; then
        install_one "$s" "$src"
      else
        note "warning: cannot refresh $s — skipped"
      fi
    done
  done
}

cmd_init() {
  refresh_global_skills
  if [ ! -f "$MANIFEST" ]; then
    cat > "$MANIFEST" <<'EOF'
# skillenv manifest — one directive per line
#
#   agents auto                     # manage whichever of claude/codex/opencode is installed
#   agents claude codex opencode    # ...or list explicitly (default: claude codex)
#   isolation strict                # strict = hide ALL global skills; merge = globals + repo (default)
#   skill github:owner/repo/path/to/skill@ref
#   skill git:ssh://git@your-git-host/group/repo.git/path/to/skill@ref
#   skill ./skills/my-local-skill
#   disable name-of-a-global-skill  # hide one global skill (works in merge mode)
EOF
    note "created $MANIFEST"
  fi
  if [ ! -f .envrc ] || ! grep -q "skillenv activate" .envrc; then
    printf 'watch_file %s\neval "$(skillenv activate)"\n' "$MANIFEST" >> .envrc
    note "wrote .envrc"
  fi
  # every run reviews this repo's skill config against what's installed —
  # skipped only when there's no TTY (an agent-driven `skillenv init` must
  # never block waiting for input)
  [ -t 0 ] && init_interactive
  [ -t 0 ] && printf '\n' >&2
  note "next: edit $MANIFEST, then run: skillenv allow && direnv allow"
  note "if you do not want materialized skills in git, add to .gitignore:"
  note "  .claude/skills/ .codex/skills/ .opencode/skills/ .agents/skills/"
}

section_header() { printf '\n%b◆ %s%b\n' "$BOLD$CYAN" "$1" "$RST" >&2; }
prompt()  { printf '  %b›%b %s ' "$CYAN" "$RST" "$1"; } # read -p string: cyan marker + question
changed() { # $1 = +|- , $2.. = text -> diff-style manifest-change feedback ('+' added, '-' removed)
  local sym=$1; shift
  case "$sym" in
    +) printf '  %b+%b %s\n' "$GREEN" "$RST" "$*" >&2 ;;
    *) printf '  %b-%b %s\n' "$DIM"   "$RST" "$*" >&2 ;;
  esac
}

init_interactive() { # every call, with a TTY: review this repo's declared skills, isolation, and global skills
  local choice rows picks name s declared_names all_rows
  local on="${GREEN}●${RST}" off="${DIM}⊘${RST}"

  parse_manifest

  # 1 — skills this repo declares
  if [ -n "$SKILLS" ]; then
    rows=""
    for s in $SKILLS; do rows="$rows$(skill_name "$s")"$'\t'"$s"$'\n'; done
    section_header "skills declared in this repo"
    hint "remove = drop the declaration; the skill stops being materialized here"
    list_rows "$rows" "$on"
    picks=$(ask_names remove)
    if [ -n "$picks" ]; then
      case " $picks " in *" all "*) picks=$(printf '%s\n' "$rows" | cut -f1 | tr '\n' ' ') ;; esac
      drop_manifest_entries skill "$picks" byname
      for name in $picks; do changed - "skill $name"; done
    fi
  fi

  # 2 — isolation mode
  section_header "isolation"
  if [ "$ISOLATION" = strict ]; then
    hint "strict (current) — hide every global skill; only repo-declared ones apply"
  else
    hint "merge (current) — inherit global skills, add repo-declared ones on top"
  fi
  read -r -p "$(prompt 'block all global skills for this repo? (y/N)')" choice || choice=""
  case "$choice" in
    y|Y|yes|YES)
      drop_isolation_lines
      printf '\nisolation strict\n' >> "$MANIFEST"
      changed + "isolation strict"
      return 0
      ;;
  esac
  drop_isolation_lines # staying in / switching to merge — merge is the default, no line needed

  all_rows=$(enabled_names)

  # 3 — skills this repo currently hides
  rows=$(filter_rows "$all_rows" "$DISABLES" only)
  if [ -n "$rows" ]; then
    section_header "hidden in this repo"
    hint "enable = inherit again · uninstall = remove everywhere (kept in backup)"
    rows=$(offer_global_uninstall "$rows" "$off")
    if [ -n "$rows" ]; then
      picks=$(ask_names enable)
      if [ -n "$picks" ]; then
        case " $picks " in *" all "*) picks=$(printf '%s\n' "$rows" | cut -f1 | tr '\n' ' ') ;; esac
        drop_manifest_entries disable "$picks"
        for name in $picks; do changed - "disable $name"; done
      fi
    fi
  fi

  # 4 — other global skills this repo inherits
  declared_names=""
  for s in $SKILLS; do declared_names="$declared_names $(skill_name "$s")"; done
  rows=$(filter_rows "$all_rows" "$DISABLES$declared_names" except)
  if [ -n "$rows" ]; then
    section_header "other global skills on this machine"
    hint "disable = hide in this repo · uninstall = remove from every repo"
    rows=$(offer_global_uninstall "$rows" "$on")
    if [ -n "$rows" ]; then
      picks=$(ask_names disable)
      if [ -n "$picks" ]; then
        case " $picks " in *" all "*) picks=$(printf '%s\n' "$rows" | cut -f1 | tr '\n' ' ') ;; esac
        for name in $picks; do
          printf 'disable %s\n' "$name" >> "$MANIFEST"
          changed + "disable $name"
        done
      fi
    fi
  fi
}

cmd_scan() { # inventory: location, name, [skillenv]-managed flag, description
  local loc dir sk name flag desc
  for loc in "claude-global:$HOME/.claude/skills"   "codex-global:$HOME/.codex/skills" \
             "agents-global:$HOME/.agents/skills"   "opencode-global:$HOME/.config/opencode/skills" \
             "claude-project:.claude/skills"        "codex-project:.codex/skills" \
             "agents-project:.agents/skills"        "opencode-project:.opencode/skills"; do
    dir=${loc#*:}
    [ -d "$dir" ] || continue
    for sk in "$dir"/*/; do
      [ -f "${sk}SKILL.md" ] || continue
      name=$(basename "$sk")
      flag=" "; [ -f "${sk}$MARKER" ] && flag="*"
      desc=$(skill_desc "${sk}SKILL.md" 96)
      printf '%-17s %s %-28s %s\n' "${loc%%:*}" "$flag" "$name" "$desc"
    done
  done
  note "* = managed by skillenv; project rows are relative to $PWD"
  note "Claude plugins are not listed — see ~/.claude/plugins/installed_plugins.json"
}

# ---------- global install / uninstall ----------
# The repo layer is declarative (.skillsrc); the global layer is imperative:
# install/uninstall write to each detected agent's global skills directory.

agent_global_dir() {
  case "$1" in
    claude)   echo "$HOME/.claude/skills" ;;
    codex)    echo "$HOME/.codex/skills" ;;
    opencode) echo "$HOME/.config/opencode/skills" ;;
  esac
}

short_source() { # compact display form of an install source
  local s=$1
  s=${s#ssh://}; s=${s#https://}; s=${s#http://}; s=${s#git@}
  s=${s/#$HOME/~}
  [ "${#s}" -gt 44 ] && s="…${s:$((${#s} - 43))}"
  printf '%s' "$s"
}

file_date() { stat -f '%Sm' -t '%Y-%m-%d' "$1" 2>/dev/null || stat -c '%y' "$1" 2>/dev/null | cut -d' ' -f1; }

list_section() { # $1 label, $2 path text, $3 dir — tree-style section (npm ls / nvm ls inspired)
  local dir=$3 entries="" sk n=0 i=0 name flag src date conn pad desc
  for sk in "$dir"/*/; do
    [ -f "${sk}SKILL.md" ] || continue
    entries="${entries}${sk}"$'\n'
    n=$((n + 1))
  done
  printf '\n%b◆ %s%b  %b%s · %s skill%s%b\n' \
    "$BOLD$CYAN" "$1" "$RST" "$DIM" "$2" "$n" "$([ "$n" -ne 1 ] && echo s)" "$RST"
  if [ "$n" -eq 0 ]; then
    printf '  %b└─ (no skills)%b\n' "$DIM" "$RST"
    return 0
  fi
  while IFS= read -r sk; do
    [ -n "$sk" ] || continue
    i=$((i + 1))
    if [ "$i" -eq "$n" ]; then conn='└─'; pad='  '; else conn='├─'; pad='│ '; fi
    name=${sk%/}; name=${name##*/}
    if [ -f "${sk}$MARKER" ]; then
      flag="${GREEN}●${RST}"
      src=$(head -1 "${sk}$MARKER" 2>/dev/null); src=${src:-managed}
      date=$(file_date "${sk}$MARKER")
    else
      flag="${DIM}○${RST}"
      src="manual"
      date=$(file_date "${sk}SKILL.md")
    fi
    printf '  %b%s%b %b %b%-24s%b %b%s · %s%b\n' \
      "$DIM" "$conn" "$RST" "$flag" "$BOLD" "$name" "$RST" "$DIM" "$(short_source "$src")" "$date" "$RST"
    desc=$(skill_desc "${sk}SKILL.md" 120)
    desc=$(disp_trunc "$desc" "$(( $(term_cols) - 10 ))") # continuation line is indented 9 cols
    [ -n "$desc" ] && printf '  %b%s%b     %b%s%b\n' "$DIM" "$pad" "$RST" "$DIM" "$desc" "$RST"
  done <<< "$entries"
}

cmd_list() { # global skills, grouped by agent
  local agent dir
  for agent in $(detect_agents); do
    dir=$(agent_global_dir "$agent")
    list_section "$agent" "${dir/#$HOME/~}" "$dir"
  done
  if [ -d "$HOME/.agents/skills" ]; then
    list_section "shared" "~/.agents/skills · opencode etc." "$HOME/.agents/skills"
  fi
  printf '\n%b● managed by skillenv   ○ installed manually%b\n' "$DIM" "$RST" >&2
}

install_one() { # $1 source string (recorded as provenance), $2 resolved dir containing SKILL.md
  local s=$1 src=$2 name agent dir dest
  name=$(skill_name "$s")
  for agent in $(detect_agents); do
    dir=$(agent_global_dir "$agent")
    mkdir -p "$dir"
    dest="$dir/$name"
    if [ -e "$dest" ] && [ ! -f "$dest/$MARKER" ]; then
      note "skip $dest — exists but not managed by skillenv ('skillenv uninstall $name' first to replace)"
      continue
    fi
    rm -rf "$dest"
    cp -R "$src" "$dest"
    rm -rf "$dest/.git"
    printf '%s\n' "$s" > "$dest/$MARKER"
    note "installed $name -> $dest"
  done
}

append_sub() { # $1 source string, $2 relative path -> source string with $2 appended before any @ref
  local s=$1 rel=$2 body ref="" last
  case "$s" in
    github:*)
      body=${s#github:}
      case "$body" in *@*) ref=${body##*@}; body=${body%@*} ;; esac
      printf 'github:%s/%s%s' "$body" "$rel" "${ref:+@$ref}"
      ;;
    git:*)
      body=${s#git:}
      last=${body##*/} # a ref can only follow the last path component (git@host: has its own @)
      case "$last" in *@*) ref=${last##*@}; body=${body%@"$ref"} ;; esac
      printf 'git:%s/%s%s' "$body" "$rel" "${ref:+@$ref}"
      ;;
    *) printf '%s/%s' "${s%/}" "$rel" ;;
  esac
}

install_picks() { # $1 source, $2 resolved dir, $3 newline-list of absolute skill dirs found under it, $4.. picks (rel path / basename / 'all')
  local s=$1 src=$2 found=$3; shift 3
  local pick d rel installed=0 matched
  for pick in "$@"; do
    matched=0
    while IFS= read -r d; do
      [ -n "$d" ] || continue
      rel=${d#"$src"/}
      if [ "$pick" = all ] || [ "$rel" = "$pick" ] || [ "${rel##*/}" = "$pick" ]; then
        install_one "$(append_sub "$s" "$rel")" "$d"
        installed=$((installed + 1))
        matched=1
      fi
    done <<< "$found"
    [ "$matched" -eq 1 ] || note "skipping '$pick' — no matching skill under $s"
  done
  [ "$installed" -gt 0 ] && note "merge-mode repos pick this up on next cd; strict repos stay unaffected"
}

browse_and_install() { # $1 source with no SKILL.md at its own root, $2 resolved local dir, $3.. optional picks (rel path / basename / 'all')
  local s=$1 src=$2; shift 2
  local found="" f n=0
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    found="$found${f%/SKILL.md}
"
    n=$((n + 1))
  done <<< "$(find "$src" -name SKILL.md | sort)"
  [ "$n" -gt 0 ] || die "no SKILL.md found under $s (searched recursively) — not a skill or a container of skills"

  if [ "$#" -gt 0 ]; then
    install_picks "$s" "$src" "$found" "$@"
    return 0
  fi

  note "no SKILL.md at $s itself — found $n skill(s) inside:"
  local d rel desc
  while IFS= read -r d; do
    [ -n "$d" ] || continue
    rel=${d#"$src"/}
    desc=$(skill_desc "$d/SKILL.md" 90)
    printf '  %-30s %s\n' "$rel" "$desc"
  done <<< "$found"

  if [ ! -t 0 ]; then
    note "install specific ones with: skillenv install $s <name-or-path> [...]  (or 'all')"
    return 0
  fi

  local choice
  read -r -p "skillenv: install which? (names, 'all', or blank to cancel): " choice || choice=""
  [ -n "$choice" ] || { note "cancelled"; return 0; }
  # shellcheck disable=SC2086
  install_picks "$s" "$src" "$found" $choice
}

cmd_install() { # <source> [name-or-path ...] -> install a skill, or browse a repo/container and install picks
  local s=${1:-} src
  [ -n "$s" ] || die "usage: skillenv install <source> [skill-name ...]   (source: github:owner/repo[/dir][@ref], git:<url>, or a local path)"
  shift
  src=$(resolve_source "$s") || die "cannot fetch $s"
  if [ -f "$src/SKILL.md" ]; then
    install_one "$s" "$src"
    note "merge-mode repos pick this up on next cd; strict repos stay unaffected"
    return 0
  fi
  browse_and_install "$s" "$src" "$@"
}

cmd_uninstall() { # <name> -> move out of every global dir into ~/.skillenv/backup
  local name=${1:-} agent dir dest bak n found=""
  [ -n "$name" ] || die "usage: skillenv uninstall <skill-name>"
  mkdir -p "$SKILLENV_HOME/backup"
  for agent in $(detect_agents); do
    dir=$(agent_global_dir "$agent")
    dest="$dir/$name"
    [ -d "$dest" ] || continue
    n=0; bak="$SKILLENV_HOME/backup/$agent-$name"
    while [ -e "$bak" ]; do n=$((n + 1)); bak="$SKILLENV_HOME/backup/$agent-$name.$n"; done
    mv "$dest" "$bak"
    note "removed $dest (backup: $bak)"
    found=1
  done
  [ -n "$found" ] || note "no global skill named '$name' for detected agents ($(detect_agents))"
}

# ---------- interactive picker (used by `init`) ----------

enabled_names() { # union of global skills across detected agents: name<TAB>description
  local agent sk name seen=" " desc
  for agent in $(detect_agents); do
    for sk in "$(agent_global_dir "$agent")"/*/; do
      [ -f "${sk}SKILL.md" ] || continue
      name=${sk%/}; name=${name##*/}
      case "$seen" in *" $name "*) continue ;; esac
      seen="$seen$name "
      desc=$(skill_desc "${sk}SKILL.md" 120) # upper bound; list_rows truncates to the terminal width
      printf '%s\t%s\n' "$name" "$desc"
    done
  done
}

term_cols() { # width of the controlling terminal; 80 when there is none. Used only to truncate text to fit,
  # never to draw a fixed-width border — so an approximate answer degrades gracefully (a char more/less), it can't break a layout.
  local c
  c=$(stty size </dev/tty 2>/dev/null | awk '{print $2}') || c=""
  case "$c" in ''|*[!0-9]*) c=80 ;; esac
  printf '%s' "$c"
}

disp_trunc() { # $1 text, $2 max display columns -> text cut to fit (… if cut). Non-ASCII counts as 2 columns
  # (good enough for CJK), so a mixed-width line never overflows and wraps. Codepoint-accurate in a UTF-8 locale.
  local s=$1 max=$2 i c cw w=0 out="" n
  n=${#s} # separate line: within a single `local`, ${#s} would read s before s=$1 takes effect
  [ "$max" -lt 2 ] && max=2
  for ((i = 0; i < n; i++)); do
    c=${s:i:1}
    # [[:ascii:]] not [ -~]: in a UTF-8 locale a bracket *range* collates by
    # locale order, not codepoints, so [ -~] only matches its endpoints. The
    # class matches any single-byte ASCII char (width 1); everything else is
    # a wide/CJK codepoint counted as 2.
    case "$c" in [[:ascii:]]) cw=1 ;; *) cw=2 ;; esac
    if (( w + cw > max )); then printf '%s…' "$out"; return; fi
    out=$out$c; w=$((w + cw))
  done
  printf '%s' "$out"
}

list_rows() { # $1 rows (name<TAB>extra), $2 already-colored glyph -> aligned one-line skill rows to stderr.
  # The description is the last thing on the line and truncated to the columns
  # actually left after the (ASCII, exactly-padded) name — so every row is one
  # clean line that never wraps, at any width, CJK included.
  local rows=$1 glyph=$2 name extra cols avail namew
  cols=$(term_cols)
  while IFS=$'\t' read -r name extra; do
    [ -n "$name" ] || continue
    if [ -n "$extra" ]; then
      namew=${#name}; [ "$namew" -lt 22 ] && namew=22
      avail=$(( cols - namew - 7 )) # 2 indent + glyph + 2 gaps + 1 right margin
      extra=$(disp_trunc "$extra" "$avail")
      printf '  %b %b%-22s%b  %b%s%b\n' "$glyph" "$BOLD" "$name" "$RST" "$DIM" "$extra" "$RST" >&2
    else
      printf '  %b %b%s%b\n' "$glyph" "$BOLD" "$name" "$RST" >&2
    fi
  done <<< "$rows"
}

hint() { printf '  %b%s%b\n' "$DIM" "$*" "$RST" >&2; } # dim caption under a header — explains what a pick does

ask_names() { # $1 verb -> echoes picks; empty = skipped/no tty. Caller must already have list_rows'd the options.
  local verb=$1 choice
  [ -t 0 ] || return 0
  read -r -p "$(printf '  %b›%b %s which? %b(names · all · ↵ skip)%b ' "$CYAN" "$RST" "$verb" "$DIM" "$RST")" choice || choice=""
  [ -n "$choice" ] || printf '  %b↵ skipped%b\n' "$DIM" "$RST" >&2
  printf '%s' "$choice"
}

filter_rows() { # $1 rows (name<TAB>extra), $2 space-separated names, $3 'only' keep matches / 'except' drop matches
  local rows=$1 set=" $2 " mode=$3 name extra
  while IFS=$'\t' read -r name extra; do
    [ -n "$name" ] || continue
    case "$mode" in
      only)   case "$set" in *" $name "*) printf '%s\t%s\n' "$name" "$extra" ;; esac ;;
      except) case "$set" in *" $name "*) ;; *) printf '%s\t%s\n' "$name" "$extra" ;; esac ;;
    esac
  done <<< "$rows"
}

drop_isolation_lines() { # remove every `isolation ...` line from the manifest (no-op if none)
  local tmp line body
  tmp=$(mktemp) || return 1
  while IFS= read -r line || [ -n "$line" ]; do
    body="${line%%#*}"
    set -f; set -- $body; set +f
    [ "${1:-}" = isolation ] && continue
    printf '%s\n' "$line"
  done < "$MANIFEST" > "$tmp"
  mv "$tmp" "$MANIFEST"
}

drop_manifest_entries() { # $1 directive (skill|disable), $2 space-separated names to drop, $3 'byname' matches skill sources by resolved name
  local directive=$1 remove=" $2 " byname=${3:-} tmp line body val
  tmp=$(mktemp) || return 1
  while IFS= read -r line || [ -n "$line" ]; do
    body="${line%%#*}"
    set -f; set -- $body; set +f
    if [ "${1:-}" = "$directive" ] && [ -n "${2:-}" ]; then
      if [ -n "$byname" ]; then val=$(skill_name "$2"); else val=$2; fi
      case "$remove" in *" $val "*) continue ;; esac
    fi
    printf '%s\n' "$line"
  done < "$MANIFEST" > "$tmp"
  mv "$tmp" "$MANIFEST"
}

offer_global_uninstall() { # $1 rows (name<TAB>desc), $2 glyph -> prints the list once; echoes rows minus any picked for uninstall (uninstalled as a side effect)
  local rows=$1 glyph=$2 picks name extra remaining=""
  list_rows "$rows" "$glyph"
  picks=$(ask_names uninstall)
  if [ -n "$picks" ]; then
    case " $picks " in *" all "*) picks=$(printf '%s\n' "$rows" | cut -f1 | tr '\n' ' ') ;; esac
    for name in $picks; do cmd_uninstall "$name"; done
    drop_manifest_entries disable "$picks"
  fi
  while IFS=$'\t' read -r name extra; do
    [ -n "$name" ] || continue
    case " $picks " in *" $name "*) continue ;; esac
    remaining="$remaining$name"$'\t'"$extra"$'\n'
  done <<< "$rows"
  printf '%s' "$remaining"
}

cmd_update() {
  local self dir tmp
  self=$(readlink -f "$0")
  dir=$(dirname "$self")
  if [ -d "$dir/.git" ]; then
    git -C "$dir" pull --ff-only >&2
    note "now at $(git -C "$dir" log -1 --format='%h %s')"
  else
    note "not a git checkout — re-downloading latest from GitHub"
    tmp=$(mktemp) \
      && curl -fsSL https://raw.githubusercontent.com/TsichiChang/skillenv/main/skillenv -o "$tmp" \
      && chmod +x "$tmp" && mv "$tmp" "$self" \
      && note "updated $self"
  fi
}

case "${1:-help}" in
  init)          cmd_init ;;
  allow)         cmd_allow ;;
  activate|sync) cmd_activate ;;
  status)        cmd_status ;;
  scan)          cmd_scan ;;
  list)          cmd_list ;;
  install)       shift; cmd_install "$@" ;;
  uninstall)     shift; cmd_uninstall "${1:-}" ;;
  prompt)        cmd_prompt ;;
  update)        cmd_update ;;
  *) sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//' ;;
esac
